# ──────────────────────────────────────────────────────────────────────────────
# Hermes Agent — environment variable reference (placeholder values only)
#
# Copy to config/.env.template and fill in real values:
#   cp config/.env.example config/.env.template
#
# config/.env.template is gitignored — never commit real credentials.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required: NAI Inference ──────────────────────────────────────────────────
OPENAI_API_KEY=REPLACE_WITH_NAI_API_KEY
OPENAI_BASE_URL=https://REPLACE_NAI_ENDPOINT/v1
NAI_MODEL=gemma-4-e4b-it

# ── Required: Telegram Gateway ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
TELEGRAM_ALLOWED_USERS=REPLACE_WITH_TELEGRAM_USER_IDS

# ── MCP Tool Servers ─────────────────────────────────────────────────────────
# SerpAPI — used by the mcp-serpapi HTTP MCP server (k8s/mcp-serpapi.yaml)
# Obtain from: https://serpapi.com/manage-api-key
SERPAPI_API_KEY=REPLACE_WITH_SERPAPI_API_KEY
# Bearer token for the mcp-serpapi HTTP endpoint — generate with: openssl rand -hex 32
MCP_SERPAPI_TOKEN=REPLACE_WITH_STRONG_RANDOM_TOKEN

# ── Optional: Additional Tool API Keys ───────────────────────────────────────
# EXA_API_KEY=
# FIRECRAWL_API_KEY=
# HONCHO_API_KEY=
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
# FAL_KEY=
# GITHUB_TOKEN=
