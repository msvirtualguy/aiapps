# Nutanix Enterprise AI endpoint (OpenAI-compatible)
NAI_BASE_URL=https://nai.utech.local/v1

# NAI API Key
NAI_API_KEY=your-nai-api-key-here

# Model names — verify these with: curl -H "Authorization: Bearer $NAI_API_KEY" $NAI_BASE_URL/models
NAI_LLM_MODEL=meta-llama-3.1-70b-instruct
NAI_VISION_MODEL=llava-1.6-34b
NAI_EMBEDDINGS_MODEL=nomic-embed-text
